// Prisma schema

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart?    // Egyirányú kapcsolat
  orders    Order[]
}

model Cart {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productName  String?
  productPrice Int?
  status       CartStatus @default(EMPTY)
  updatedAt    DateTime @updatedAt
}

model Order {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productName  String
  productPrice Int
  status       OrderStatus @default(PENDING)
  createdAt    DateTime @default(now())
}

model members {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name       String
  gender     members_gender?
  birth_date DateTime @db.Date
  banned     Boolean  @default(false)
  created_at DateTime?
  updated_at DateTime?
}

model Leaderboard {
  id        Int      @id @default(autoincrement())
  username  String
  score     Int
  rounds    Int
  createdAt DateTime @default(now())
}

enum members_gender {
  M
  F
}

enum CartStatus {
  EMPTY
  FILLED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}